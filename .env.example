# Required for stock data fetch
TUSHARE_TOKEN=your_tushare_token

# Required for direct LLM analysis/recommend workflows
LLM_API_KEY=your_llm_api_key

# Optional direct LLM endpoint config
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SEC=60

# Required for Feishu notifications
FEISHU_WEBHOOK=your_feishu_webhook

# true = local debug output, false = normal notify flow
DEBUG_MODE=false

# Analysis stock list
MY_STOCKS=601880.SH,600157.SH,603010.SH,002372.SZ,600905.SH,600009.SH,600010.SH

# Allowed exchanges: SH,SZ,BJ (supports aliases in code)
ALLOWED_EXCHANGES=SH,SZ,BJ

# Optional industry filter for recommendation workflow
RECOMMENDER_INDUSTRIES=

# RSS URLs (comma-separated). If empty, falls back to NEWS_RSS_FEEDS_FILE.
NEWS_RSS_FEEDS=

# RSS source file (one URL per line)
NEWS_RSS_FEEDS_FILE=tradeeye/resources/news_feeds.txt

# News filter window (hours)
NEWS_LOOKBACK_HOURS=24

# Max news items per push
NEWS_MAX_ITEMS=15

# Optional include keywords (comma-separated OR)
NEWS_INCLUDE_KEYWORDS=

# Optional exclude keywords (comma-separated OR)
NEWS_EXCLUDE_KEYWORDS=

# true = still push message when no matched news
NEWS_PUSH_WHEN_EMPTY=false

# News message template path
NEWS_TEMPLATE_FILE=tradeeye/resources/news_template.txt

# Exclude patterns for external upload tools (comma-separated)
UPLOAD_EXCLUDE_PATTERNS=workspace,*.code-workspace
